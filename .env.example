# Copy this file to .env and fill in your real values.
# Get the token from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=your-bot-token-here

# Optional: set to a server (guild) ID during development so slash commands
# appear instantly in that server instead of taking up to an hour to sync globally.
# Leave blank to register commands globally.
DEV_GUILD_ID=
